{
  "name": "@rotorjs/jpl",
  "version": "0.6.1",
  "description": "Rotor",
  "author": {
    "name": "Aaron Burmeister"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotorjs/jpl.git"
  },
  "bugs": {
    "url": "https://github.com/rotorjs/jpl/issues"
  },
  "homepage": "https://github.com/rotorjs/",
  "type": "module",
  "keywords": [
    "state",
    "dashboards",
    "jpl"
  ],
  "files": [
    "dist"
  ],
  "types": "./dist/types/main.d.ts",
  "main": "./dist/esm/main.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/main.d.ts",
        "default": "./dist/esm/main.js"
      }
    },
    "./main": null,
    "./*": {
      "import": {
        "types": "./dist/types/*",
        "default": "./dist/esm/*"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b ./tsconfig-build.json && vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "prettify": "prettier . --write",
    "preview": "vite preview",
    "postversion": "git commit -am$npm_package_version",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jplorg/jpl": "^2.1.2",
    "@rotorjs/dashboard": "^0.4.0",
    "@types/node": "^25.9.3",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unplugin-dts": "^1.0.2",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "@jplorg/jpl": "^2.0.0 || ^1.0.0",
    "@rotorjs/dashboard": "^0.4.0"
  },
  "dependencies": {
    "object-hash": "^3.0.0"
  }
}
